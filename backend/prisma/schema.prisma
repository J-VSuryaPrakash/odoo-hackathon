generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id              Int              @id @default(autoincrement())
  roleName        String           @unique
  description     String?
  rolePermissions RolePermission[]
  users           User[]
}

model User {
  id              Int        @id @default(autoincrement())
  firstName       String
  lastName        String?
  email           String     @unique
  passwordHash    String
  phone           String?
  roleId          Int
  status          UserStatus @default(ACTIVE)
  failedAttempts  Int        @default(0)
  lastLogin       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  settingsUpdated Setting[]
  createdTrips    Trip[]
  role            Role       @relation(fields: [roleId], references: [id])
}

model Permission {
  id              Int              @id @default(autoincrement())
  permissionName  String           @unique
  moduleName      String?
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Vehicle {
  id              Int              @id @default(autoincrement())
  registrationNo  String           @unique
  vehicleName     String?
  vehicleType     VehicleType?
  model           String?
  capacityKg      Decimal?         @db.Decimal(10, 2)
  purchaseCost    Decimal?         @db.Decimal(12, 2)
  odometer        Int              @default(0)
  fuelType        FuelType?
  purchaseDate    DateTime?        @db.Date
  status          VehicleStatus    @default(AVAILABLE)
  createdAt       DateTime         @default(now())
  expenses        Expense[]
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
  trips           Trip[]
}

model Driver {
  id            Int                @id @default(autoincrement())
  driverName    String
  licenseNumber String?            @unique
  licenseType   DriverLicenseType?
  phone         String?
  address       String?
  licenseExpiry DateTime?          @db.Date
  joiningDate   DateTime?          @db.Date
  safetyScore   Decimal            @default(0) @db.Decimal(5, 2)
  status        DriverStatus       @default(AVAILABLE)
  createdAt     DateTime           @default(now())
  documents     DriverDocument[]
  trips         Trip[]
}

model DriverDocument {
  id           Int       @id @default(autoincrement())
  driverId     Int
  documentName String?
  expiryDate   DateTime? @db.Date
  filePath     String?
  driver       Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model Trip {
  id              Int        @id @default(autoincrement())
  tripNo          String?    @unique
  source          String?
  destination     String?
  vehicleId       Int?
  driverId        Int?
  cargoWeight     Decimal?   @db.Decimal(10, 2)
  plannedDistance Decimal?   @db.Decimal(10, 2)
  actualDistance  Decimal?   @db.Decimal(10, 2)
  estimatedTime   Int?
  actualTime      Int?
  dispatchTime    DateTime?
  arrivalTime     DateTime?
  status          TripStatus @default(DRAFT)
  createdBy       Int?
  createdAt       DateTime   @default(now())
  expenses        Expense[]
  fuelLogs        FuelLog[]
  creator         User?      @relation(fields: [createdBy], references: [id])
  driver          Driver?    @relation(fields: [driverId], references: [id])
  vehicle         Vehicle?   @relation(fields: [vehicleId], references: [id])
}

model MaintenanceLog {
  id          Int               @id @default(autoincrement())
  vehicleId   Int?
  serviceType String?
  description String?
  cost        Decimal?          @db.Decimal(10, 2)
  serviceDate DateTime?         @db.Date
  status      MaintenanceStatus @default(AVAILABLE)
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id            Int       @id @default(autoincrement())
  vehicleId     Int?
  tripId        Int?
  date          DateTime? @db.Date
  liters        Decimal?  @db.Decimal(10, 2)
  pricePerLiter Decimal?  @db.Decimal(10, 2)
  amount        Decimal?  @db.Decimal(10, 2)
  fuelStation   String?
  odometer      Int?
  trip          Trip?     @relation(fields: [tripId], references: [id])
  vehicle       Vehicle?  @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id          Int          @id @default(autoincrement())
  tripId      Int?
  vehicleId   Int?
  expenseType ExpenseType?
  amount      Decimal?     @db.Decimal(10, 2)
  remarks     String?
  expenseDate DateTime?    @db.Date
  trip        Trip?        @relation(fields: [tripId], references: [id])
  vehicle     Vehicle?     @relation(fields: [vehicleId], references: [id])
}

model Setting {
  id           Int      @id @default(autoincrement())
  depotName    String?
  currency     String?
  distanceUnit String?
  updatedBy    Int?
  updatedAt    DateTime @updatedAt
  updatedUser  User?    @relation(fields: [updatedBy], references: [id])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum VehicleType {
  Van
  Truck
  Mini
  Trailer
  Other
}

enum FuelType {
  Petrol
  Diesel
  Electric
  CNG
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverLicenseType {
  LMV
  HMV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  AVAILABLE
  IN_SHOP
}

enum ExpenseType {
  TOLL
  REPAIR
  PARKING
  MISC
  PENALTY
}
